# SK Music — environment configuration. Copy to `.env` for local overrides.
# Everything has a sensible default; nothing here is a secret except where noted.

# --- Catalog source (the whitelisted music catalog is fetched, not committed) ---
# GitHub repo whose Releases hold the corpus snapshot (corpus-YYYYMMDD.db.gz). Public; no auth needed.
CORPUS_REPO=ZemerTeam/zemer-search
# Where the fetched SQLite corpus lands / is read from.
CORPUS_DB=data/corpus.db
# Upstream API for the curated playlists (baked into dist/ at build time).
CATALOG_API=https://search.zemer.io

# --- Build / deploy ---
# Canonical site origin — used for sitemaps + Open Graph image URLs.
SITE_URL=https://skmusic.shalomkarr.workers.dev
# Optional: Cloudflare Web Analytics beacon token (public client id; injected into the shipped HTML).
CF_ANALYTICS_TOKEN=

# --- CI secrets (set as GitHub Actions repository secrets, NOT committed) ---
# CLOUDFLARE_API_TOKEN  — required for `wrangler deploy` in CI.
# GITHUB_TOKEN          — provided automatically by GitHub Actions; used to avoid the unauthenticated
#                         GitHub API rate limit when fetching the catalog release.
