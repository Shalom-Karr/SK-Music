{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SK Music",
  "version": "0.1.2",
  "identifier": "dev.shalomkarr.skmusic",
  "build": {
    "frontendDist": "./frontend",
    "devUrl": "https://skmusic.shalomkarr.workers.dev"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SK Music",
        "url": "index.html",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "withGlobalTauri": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["skmusic"]
      }
    },
    "updater": {
      "endpoints": [
        "https://skmusic.shalomkarr.workers.dev/updates/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM2RUEzRUYzMTYyMDVERjIKUldUeVhTQVc4ejdxTnVqc0hwVVNQYWd1TUdYZ3RKM0tQK1BQQjk4YlR5WUxaak5mcEwxbVI5TngK"
    }
  }
}
